{
  "name": "smart-pdf-compressor",
  "version": "0.1.0",
  "description": "Production-ready macOS CLI for rule-based PDF analysis and Ghostscript-based compression.",
  "type": "module",
  "main": "src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/api.js"
    },
    "./config": {
      "types": "./types/config.d.ts",
      "import": "./src/config/defaults.js"
    },
    "./config-schema": "./schema/smart-pdf.config.schema.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "smart-pdf-compressor": "./src/index.js",
    "spdf": "./src/index.js"
  },
  "files": [
    "src",
    "types",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "find src -name '*.js' -print0 | xargs -0 -n 1 node --check",
    "doctor": "node src/index.js --doctor",
    "pack:dry": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.394"
  },
  "keywords": [
    "pdf",
    "compression",
    "ghostscript",
    "macos",
    "cli",
    "batch-processing"
  ],
  "author": "cobchenyuk <cobchenyuk@gmail.com>",
  "homepage": "https://www.linkedin.com/in/sobchenyuk-andrey/",
  "license": "MIT"
}
