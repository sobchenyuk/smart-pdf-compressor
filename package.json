{
  "name": "smart-pdf-compressor",
  "version": "0.1.0",
  "description": "Smart PDF compression CLI with Ghostscript, automatic analysis, and batch processing for macOS",
  "type": "module",
  "main": "src/index.js",
  "types": "./types/index.d.ts",
  "preferGlobal": true,
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/api.js"
    },
    "./config": {
      "types": "./types/config.d.ts",
      "import": "./src/config/defaults.js"
    },
    "./config-schema": "./schema/smart-pdf.config.schema.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "smart-pdf-compressor": "./src/index.js",
    "spdf": "./src/index.js"
  },
  "files": [
    "src",
    "types",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "find src -name '*.js' -print0 | xargs -0 -n 1 node --check",
    "doctor": "node src/index.js --doctor",
    "pack:dry": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.394"
  },
  "keywords": [
    "pdf",
    "pdf-compression",
    "pdf-optimizer",
    "ghostscript",
    "cli",
    "pdf-cli",
    "pdf-tools",
    "batch-processing",
    "macos",
    "pdf-reduce-size"
  ],
  "author": "cobchenyuk <cobchenyuk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/sobchenyuk/smart-pdf-compressor.git"
  },
  "bugs": {
    "url": "https://github.com/sobchenyuk/smart-pdf-compressor/issues"
  },
  "homepage": "https://github.com/sobchenyuk/smart-pdf-compressor",
  "license": "MIT"
}
